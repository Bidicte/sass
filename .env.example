// ===== .env.example =====
# API Configuration
VITE_API_BASE_URL=https://your-api.com/api
VITE_AUTH_LOGIN_ENDPOINT=/auth/login
VITE_AUTH_REFRESH_ENDPOINT=/auth/refresh
VITE_AUTH_LOGOUT_ENDPOINT=/auth/logout
VITE_AUTH_PROFILE_ENDPOINT=/auth/profile
VITE_AUTH_REGISTER_ENDPOINT=/auth/register

# Token Storage Keys
VITE_TOKEN_KEY=access_token
VITE_REFRESH_TOKEN_KEY=refresh_token
VITE_USER_DATA_KEY=user_data

# Security Settings
VITE_TOKEN_EXPIRY_BUFFER=300000
VITE_SESSION_TIMEOUT=86400000
VITE_MAX_LOGIN_ATTEMPTS=5
VITE_LOCKOUT_DURATION=900000

# App Settings
VITE_APP_ENV=production
VITE_API_TIMEOUT=10000
VITE_ENABLE_REMEMBER_ME=true